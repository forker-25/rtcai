# rtcai configuration
# Place this file at ~/.rtcai/.env

GROQ_API_KEY=your_groq_api_key_here

MODEL=llama-3.3-70b-versatile

# Max tokens the AI generates per response
MAX_TOKENS=1024

# Context history file
CTX_FILE=.rtcai/ctx.json

# System prompt file (leave blank to use built in default)
# SYS_PROMPT_FILE=.rtcai/system.txt